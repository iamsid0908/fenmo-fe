# Dependencies (restored by npm ci inside Docker)
node_modules
npm-debug.log*

# Next.js build output (rebuilt inside Docker)
.next
out

# Local env files — never bake secrets into the image
.env
.env.*
!.env.example

# Git / editor
.git
.gitignore
.DS_Store
*.md

# Tests / tooling
coverage
.nyc_output

# Docker files themselves
Dockerfile*
docker-compose*.yml
.dockerignore
